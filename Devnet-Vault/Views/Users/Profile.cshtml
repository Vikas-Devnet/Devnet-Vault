@using System.IdentityModel.Tokens.Jwt
@{
    ViewData["Title"] = "My Profile";
    var name = User.FindFirst(JwtRegisteredClaimNames.Name)?.Value ?? "User";
    var initials = string.Join("", name.Split(' ').Select(x => x[0])).ToUpper();
}

@section Styles {
    <style>
        .profile-grid {
            display: grid;
            grid-template-columns: 350px 1fr;
            gap: 1.5rem;
        }

        @@media (max-width: 860px) {
            .profile-grid {
                grid-template-columns: 1fr;
            }
        }

        .vault-card {
            background: var(--color-surface);
            border: 1px solid var(--color-border);
            border-radius: var(--r-lg);
            box-shadow: var(--shadow-sm);
            overflow: hidden;
        }

        .vault-card-header {
            padding: .9rem 1.25rem;
            border-bottom: 1px solid var(--color-border);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .vault-card-title {
            font-size: .875rem;
            font-weight: 700;
            color: var(--color-secondary);
            display: flex;
            align-items: center;
            gap: .5rem;
        }

            .vault-card-title i {
                color: var(--color-primary);
                font-size: 1rem;
            }

        .vault-card-body {
            padding: 1.25rem;
        }

        .profile-avatar-lg {
            width: 88px;
            height: 88px;
            border-radius: 50%;
            background: linear-gradient(135deg, #2563EB, #6366F1);
            color: #fff;
            font-size: 1.9rem;
            font-weight: 800;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1rem;
            border: 3px solid var(--color-primary-light);
            box-shadow: 0 0 0 4px var(--color-bg);
        }

        .profile-name {
            font-size: 1.85rem;
            font-weight: 700;
            color: var(--color-secondary);
            margin-bottom: .2rem;
            text-align: center;
        }

        .profile-email {
            font-size: .88rem;
            color: var(--color-text-muted);
            margin-bottom: .9rem;
            text-align: center;
            word-break: break-all;
        }

        .profile-badge {
            display: inline-flex;
            align-items: center;
            gap: .35rem;
            padding: .3rem .75rem;
            border-radius: var(--r-full);
            font-size: .73rem;
            font-weight: 600;
        }

        .badge-success {
            background: #dcfce7;
            color: #15803d;
        }

        .badge-warning {
            background: #fef3c7;
            color: #92400e;
        }

        .badge-primary {
            background: var(--color-primary-light);
            color: var(--color-primary);
        }

        .form-group {
            margin-bottom: 1rem;
        }

        .form-label {
            display: block;
            font-size: .78rem;
            font-weight: 600;
            color: var(--color-text-secondary);
            margin-bottom: .35rem;
        }

        .form-control-vault {
            width: 100%;
            padding: .6rem .9rem;
            background: var(--color-bg);
            border: 1.5px solid var(--color-border);
            border-radius: var(--r-md);
            font-size: .875rem;
            color: var(--color-text-primary);
            font-family: inherit;
            outline: none;
            transition: border-color 150ms, box-shadow 150ms, background 150ms;
            box-sizing: border-box;
        }

            .form-control-vault:focus {
                border-color: var(--color-primary);
                box-shadow: 0 0 0 3px rgba(37,99,235,.07);
                background: #fff;
            }

            .form-control-vault.is-invalid {
                border-color: #ef4444;
                box-shadow: 0 0 0 3px rgba(239,68,68,.07);
            }

            .form-control-vault.is-valid {
                border-color: #22c55e;
            }

        .field-error {
            font-size: .72rem;
            color: #ef4444;
            margin-top: .3rem;
            display: none;
            font-weight: 500;
        }

            .field-error.show {
                display: block;
            }

        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: .9rem;
        }

        @@media (max-width: 520px) {
            .form-row {
                grid-template-columns: 1fr;
            }
        }

        .input-with-action {
            display: flex;
            gap: .5rem;
            align-items: flex-start;
        }

            .input-with-action > div {
                flex: 1;
                min-width: 0;
            }

        .verify-badge {
            display: inline-flex;
            align-items: center;
            gap: .3rem;
            font-size: .71rem;
            font-weight: 600;
            padding: .62rem .7rem;
            border-radius: var(--r-md);
            white-space: nowrap;
            flex-shrink: 0;
            border: 1.5px solid transparent;
            line-height: 1;
        }

        .verified {
            background: #dcfce7;
            color: #15803d;
            border-color: #bbf7d0;
        }

        .unverified {
            background: #fef3c7;
            color: #92400e;
            border-color: #f59e0b;
            cursor: pointer;
            transition: background 150ms;
        }

            .unverified:hover {
                background: #fde68a;
            }

        .btn-vault-primary {
            display: inline-flex;
            align-items: center;
            gap: .45rem;
            padding: .6rem 1.25rem;
            background: var(--color-primary);
            color: #fff;
            border: none;
            border-radius: var(--r-full);
            font-size: .875rem;
            font-weight: 600;
            cursor: pointer;
            font-family: inherit;
            transition: background 150ms, box-shadow 150ms;
        }

            .btn-vault-primary:hover {
                background: #1d4ed8;
                box-shadow: var(--shadow-md);
            }

            .btn-vault-primary:disabled {
                opacity: .55;
                cursor: not-allowed;
            }

        .btn-vault-outline {
            display: inline-flex;
            align-items: center;
            gap: .45rem;
            padding: .6rem 1.25rem;
            background: transparent;
            color: var(--color-text-secondary);
            border: 1.5px solid var(--color-border);
            border-radius: var(--r-full);
            font-size: .875rem;
            font-weight: 600;
            cursor: pointer;
            font-family: inherit;
            transition: border-color 150ms, color 150ms, background 150ms;
        }

            .btn-vault-outline:hover {
                border-color: var(--color-primary);
                color: var(--color-primary);
                background: var(--color-primary-light);
            }

        .btn-danger-outline {
            color: #dc2626 !important;
            border-color: #fecaca !important;
        }

            .btn-danger-outline:hover {
                background: #e75151 !important;
                border-color: #dc2626 !important;
            }

        .btn-actions {
            display: flex;
            align-items: center;
            gap: .75rem;
            flex-wrap: wrap;
            margin-top: 1.25rem;
            padding-top: 1.25rem;
            border-top: 1px solid var(--color-border);
        }

        .pw-wrap {
            position: relative;
        }

            .pw-wrap .form-control-vault {
                padding-right: 2.6rem;
            }

        .pw-toggle {
            position: absolute;
            right: .75rem;
            top: 50%;
            transform: translateY(-50%);
            color: var(--color-text-muted);
            cursor: pointer;
            font-size: .95rem;
            background: none;
            border: none;
            padding: 0;
            line-height: 1;
            transition: color 150ms;
        }

            .pw-toggle:hover {
                color: var(--color-primary);
            }

        .pw-strength {
            display: flex;
            gap: .3rem;
            margin-top: .45rem;
        }

        .pw-bar {
            height: 4px;
            flex: 1;
            border-radius: var(--r-full);
            background: var(--color-border);
            transition: background .25s;
        }

            .pw-bar.weak {
                background: #ef4444;
            }

            .pw-bar.fair {
                background: #f59e0b;
            }

            .pw-bar.good {
                background: #22c55e;
            }

            .pw-bar.strong {
                background: #16a34a;
            }

        .pw-hint {
            font-size: .71rem;
            color: var(--color-text-muted);
            margin-top: .3rem;
        }

        .danger-zone {
            border-color: #fecaca !important;
        }

            .danger-zone .vault-card-header {
                background: #fff5f5;
                border-bottom-color: #fecaca;
            }

            .danger-zone .vault-card-title {
                color: #dc2626;
            }

                .danger-zone .vault-card-title i {
                    color: #dc2626;
                }

        .danger-text {
            font-size: .84rem;
            color: var(--color-text-secondary);
            margin-bottom: .75rem;
        }

        .inline-feedback {
            font-size: .78rem;
            font-weight: 500;
            padding: .45rem .75rem;
            border-radius: var(--r-md);
            margin-top: .6rem;
            display: none;
        }

            .inline-feedback.success {
                display: flex;
                align-items: center;
                gap: .4rem;
                background: #f0fdf4;
                color: #15803d;
                border: 1px solid #bbf7d0;
            }

            .inline-feedback.error {
                display: flex;
                align-items: center;
                gap: .4rem;
                background: #fef2f2;
                color: #dc2626;
                border: 1px solid #fecaca;
            }

        .otp-inputs {
            display: flex;
            gap: .55rem;
            justify-content: center;
            margin: 1.25rem 0;
        }

        .otp-box {
            width: 46px;
            height: 52px;
            text-align: center;
            font-size: 1.35rem;
            font-weight: 700;
            border: 1.5px solid var(--color-border);
            border-radius: var(--r-md);
            background: var(--color-bg);
            color: var(--color-secondary);
            font-family: inherit;
            outline: none;
            transition: border-color 150ms, box-shadow 150ms;
        }

            .otp-box:focus {
                border-color: var(--color-primary);
                box-shadow: 0 0 0 3px rgba(37,99,235,.08);
                background: #fff;
            }

            .otp-box.is-invalid {
                border-color: #ef4444;
            }
    </style>
}

<div class="profile-grid">

    <!-- ══ LEFT ══ -->
    <div style="display:flex;flex-direction:column;gap:1.25rem;">

        <!-- Identity card -->
        <div class="vault-card">
            <div class="vault-card-body" style="padding:1.75rem 1.25rem 1.25rem;">
                <div class="profile-avatar-lg" id="avatarDisplay">@(initials)</div>
                <div class="profile-name" id="displayName">@(name)</div>
                <div class="profile-email" id="displayEmail"></div>
                <div style="text-align:center;">
                    <span class="profile-badge badge-success" id="emailVerifiedBadge" style="display:none;">
                        <i class="bi bi-patch-check-fill"></i> Email verified
                    </span>
                    <span class="profile-badge badge-warning" id="emailUnverifiedBadge" style="display:none;">
                        <i class="bi bi-exclamation-circle-fill"></i> Email not verified
                    </span>
                </div>
            </div>
        </div>

        <!-- Subscription -->
        <div class="vault-card">
            <div class="vault-card-header">
                <span class="vault-card-title"><i class="bi bi-award-fill"></i> Subscription</span>
                <a asp-area="" asp-controller="Home" asp-action="Storage"
                   style="font-size:.75rem;color:var(--color-primary);font-weight:600;text-decoration:none;">
                    Upgrade →
                </a>
            </div>
            <div class="vault-card-body">
                <div style="display:flex;align-items:center;gap:.6rem;margin-bottom:.5rem;">
                    <span class="profile-badge badge-primary">
                        <i class="bi bi-lightning-charge-fill"></i>
                        <span id="subPlanName">—</span>
                    </span>
                </div>
                <div style="font-size:.78rem;color:var(--color-text-muted);">
                    Expires: <span id="subExpiry" style="font-weight:600;color:var(--color-secondary);">—</span>
                </div>
            </div>
        </div>

    </div>

    <!-- ══ RIGHT ══ -->
    <div style="display:flex;flex-direction:column;gap:1.25rem;">

        <!-- Personal Information -->
        <div class="vault-card">
            <div class="vault-card-header">
                <span class="vault-card-title"><i class="bi bi-person-lines-fill"></i> Personal Information</span>
            </div>
            <div class="vault-card-body">
                <form id="profileForm" onsubmit="saveProfile(event)" novalidate>
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label" for="inp_fullname">
                                Full Name <span style="color:#ef4444">*</span>
                            </label>
                            <input class="form-control-vault" type="text" id="inp_fullname"
                                   name="FullName" placeholder="Your full name" autocomplete="name" />
                            <div class="field-error" id="err_fullname">Full name is required.</div>
                        </div>
                        <div class="form-group">
                            <label class="form-label" for="inp_nationality">
                                Nationality <span style="color:#ef4444">*</span>
                            </label>
                            <input class="form-control-vault" type="text" id="inp_nationality"
                                   name="Nationality" placeholder="e.g. Indian" autocomplete="country-name" />
                            <div class="field-error" id="err_nationality">Nationality is required.</div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label" for="inp_email">
                            Email Address <span style="color:#ef4444">*</span>
                        </label>
                        <div class="input-with-action">
                            <div>
                                <input class="form-control-vault" type="email" id="inp_email"
                                       name="Email" placeholder="you@example.com" autocomplete="email" />
                                <div class="field-error" id="err_email">Enter a valid email address.</div>
                            </div>
                            <span class="verify-badge verified" id="verifiedTag" style="display:none;">
                                <i class="bi bi-patch-check-fill"></i> Verified
                            </span>
                            <span class="verify-badge unverified" id="unverifiedTag" style="display:none;"
                                  onclick="startEmailVerification()" title="Click to verify your email">
                                <i class="bi bi-exclamation-circle-fill"></i> Verify
                            </span>
                        </div>
                    </div>

                    <div class="btn-actions">
                        <button type="submit" class="btn-vault-primary" id="saveProfileBtn" disabled>
                            <i class="bi bi-check2"></i> Save Changes
                        </button>
                        <button type="button" class="btn-vault-outline" onclick="loadProfile()">
                            <i class="bi bi-arrow-counterclockwise"></i> Reset
                        </button>
                    </div>
                    <div class="inline-feedback" id="profileFeedback"></div>
                </form>
            </div>
        </div>

        <!-- Change Password -->
        <div class="vault-card">
            <div class="vault-card-header">
                <span class="vault-card-title"><i class="bi bi-shield-lock-fill"></i> Change Password</span>
            </div>
            <div class="vault-card-body">
                <form id="passwordForm" onsubmit="changePassword(event)" novalidate>
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label" for="inp_email_pw">
                                Registered Email <span style="color:#ef4444">*</span>
                            </label>
                            <input class="form-control-vault" type="email" id="inp_email_pw"
                                   placeholder="Your account email" autocomplete="email" />
                            <div class="field-error" id="err_email_pw">Enter a valid email address.</div>
                        </div>
                        <div class="form-group">
                            <label class="form-label" for="inp_newpw">
                                New Password <span style="color:#ef4444">*</span>
                            </label>
                            <div class="pw-wrap">
                                <input class="form-control-vault" type="password" id="inp_newpw"
                                       placeholder="Min. 8 characters" autocomplete="new-password"
                                       oninput="checkStrength(this.value)" />
                                <button type="button" class="pw-toggle"
                                        onclick="togglePw('inp_newpw', this)" tabindex="-1">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                            <div class="pw-strength">
                                <div class="pw-bar" id="bar1"></div>
                                <div class="pw-bar" id="bar2"></div>
                                <div class="pw-bar" id="bar3"></div>
                                <div class="pw-bar" id="bar4"></div>
                            </div>
                            <div class="pw-hint" id="pwHint">Enter a password</div>
                            <div class="field-error" id="err_newpw">Password must be at least 8 characters.</div>
                        </div>
                    </div>

                    <div class="btn-actions">
                        <button type="submit" class="btn-vault-primary" id="changePwBtn" disabled>
                            <i class="bi bi-lock-fill"></i> Update Password
                        </button>
                    </div>
                    <div class="inline-feedback" id="pwFeedback"></div>
                    <p style="font-size:.74rem;color:var(--color-text-muted);margin-top:.75rem;margin-bottom:0;">
                        <i class="bi bi-info-circle me-1"></i>
                        An OTP will be sent to your email to confirm the password change.
                    </p>
                </form>
            </div>
        </div>

        <!-- Danger Zone -->
        <div class="vault-card danger-zone">
            <div class="vault-card-header">
                <span class="vault-card-title">
                    <i class="bi bi-exclamation-triangle-fill"></i> Danger Zone
                </span>
            </div>
            <div class="vault-card-body">
                <p class="danger-text">
                    Permanently deletes your account, all files, passwords, and data stored in Vault.
                    This action <strong>cannot be undone</strong>.
                </p>
                <button class="btn-vault-outline btn-danger-outline" onclick="confirmDeleteAccount()">
                    <i class="bi bi-trash3-fill"></i> Delete My Account
                </button>
            </div>
        </div>

    </div>
</div>

<!-- ══ OTP MODAL ══ -->
<div id="otpModalBackdrop"
     style="display:none;position:fixed;inset:0;z-index:3000;
            background:rgba(15,23,42,.45);backdrop-filter:blur(3px);
            align-items:center;justify-content:center;">
    <div style="background:var(--color-surface);border:1px solid var(--color-border);
                border-radius:var(--r-lg);box-shadow:var(--shadow-xl);
                width:100%;max-width:370px;overflow:hidden;margin:1rem;
                animation:dropIn .2s ease both;">
        <div style="padding:1.1rem 1.25rem .8rem;border-bottom:1px solid var(--color-border);
                    display:flex;align-items:center;justify-content:space-between;">
            <div style="font-weight:700;color:var(--color-secondary);font-size:.9rem;
                        display:flex;align-items:center;gap:.5rem;">
                <i class="bi bi-envelope-check-fill" style="color:var(--color-primary)"></i>
                OTP Verification
            </div>
            <button onclick="closeOtpModal()"
                    style="background:none;border:none;font-size:1.05rem;
                           color:var(--color-text-muted);cursor:pointer;line-height:1;">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
        <div style="padding:1.25rem;">
            <p id="otpModalMsg"
               style="font-size:.83rem;color:var(--color-text-secondary);
                      text-align:center;margin-bottom:0;line-height:1.55;">
                We've sent a 6-digit code to your email.
            </p>
            <div class="otp-inputs">
                <input class="otp-box" maxlength="1" type="text" inputmode="numeric" pattern="[0-9]" />
                <input class="otp-box" maxlength="1" type="text" inputmode="numeric" pattern="[0-9]" />
                <input class="otp-box" maxlength="1" type="text" inputmode="numeric" pattern="[0-9]" />
                <input class="otp-box" maxlength="1" type="text" inputmode="numeric" pattern="[0-9]" />
                <input class="otp-box" maxlength="1" type="text" inputmode="numeric" pattern="[0-9]" />
                <input class="otp-box" maxlength="1" type="text" inputmode="numeric" pattern="[0-9]" />
            </div>
            <div class="inline-feedback" id="otpFeedback"
                 style="justify-content:center;margin-bottom:.6rem;"></div>
            <button class="btn-vault-primary" style="width:100%;justify-content:center;"
                    id="verifyOtpBtn" onclick="verifyOtp()">
                <i class="bi bi-check2-circle"></i> Verify &amp; Continue
            </button>
            <div style="text-align:center;margin-top:.85rem;">
                <button onclick="resendOtp()"
                        style="background:none;border:none;font-size:.78rem;
                               color:var(--color-primary);cursor:pointer;
                               font-weight:600;font-family:inherit;">
                    <i class="bi bi-arrow-repeat me-1"></i> Resend code
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let _otpKey          = null;
        let _otpMode         = null; 
        let _pendingEmail    = null;
        let _pendingPassword = null;
        let _currentProfile  = {};

        document.addEventListener('DOMContentLoaded', () => {
            loadProfile();
            initOtpInputs();

            [['inp_fullname', 'err_fullname', isNonEmpty],
             ['inp_nationality', 'err_nationality', isNonEmpty],
             ['inp_email', 'err_email', isValidEmail],
             ['inp_email_pw', 'err_email_pw', isValidEmail],
             ['inp_newpw', 'err_newpw', isValidPw]
            ].forEach(([id, err, fn]) =>
                document.getElementById(id)?.addEventListener('blur', () => validateField(id, err, fn)));

            ['inp_fullname', 'inp_nationality', 'inp_email'].forEach(id => {
                document.getElementById(id)?.addEventListener('input', syncSaveBtn);
            });

            document.getElementById('inp_newpw')?.addEventListener('input', () => {
                const val = document.getElementById('inp_newpw').value;
                document.getElementById('changePwBtn').disabled = !isValidPw(val);
            });
        });

        function syncSaveBtn() {
            const changed =
                document.getElementById('inp_fullname').value.trim()    !== (_currentProfile.fullName    || '') ||
                document.getElementById('inp_nationality').value.trim() !== (_currentProfile.nationality || '') ||
                document.getElementById('inp_email').value.trim()       !== (_currentProfile.email       || '');
            document.getElementById('saveProfileBtn').disabled = !changed;
        }

        async function loadProfile() {
            try {
                const res  = await fetch('/api/account/profile/getById', { credentials: 'include' });
                const data = await res.json();
                if (!data.isSuccess) {
                    Vault.alert('error', data.message || 'Failed to load profile', 4000);
                    return;
                }

                const p = data.result;
                _currentProfile = p;

                setVal('inp_fullname',    p.fullName    || '');
                setVal('inp_nationality', p.nationality || '');
                setVal('inp_email',       p.email       || '');
                setVal('inp_email_pw',    p.email       || '');

                document.getElementById('displayName').textContent  = p.fullName || '';
                document.getElementById('displayEmail').textContent = p.email    || '';

                setEmailVerifiedUI(p.isEmailConfirmed);

                document.getElementById('subPlanName').textContent = p.subscriptionName || 'Free';
                document.getElementById('subExpiry').textContent   =
                    p.subscriptionExpiry
                        ? new Date(p.subscriptionExpiry).toLocaleDateString('en-IN',
                            { day: '2-digit', month: 'short', year: 'numeric' })
                        : 'N/A';

                document.getElementById('saveProfileBtn').disabled = true;
                document.getElementById('changePwBtn').disabled    = true;

                clearAllValidation();
            } catch {
                Vault.alert('error', 'Could not load profile.', 4000);
            }
        }

        function setVal(id, val) {
            const el = document.getElementById(id);
            if (el) el.value = val;
        }

        function setEmailVerifiedUI(verified) {
            document.getElementById('verifiedTag').style.display          = verified ? '' : 'none';
            document.getElementById('unverifiedTag').style.display        = verified ? 'none' : '';
            document.getElementById('emailVerifiedBadge').style.display   = verified ? '' : 'none';
            document.getElementById('emailUnverifiedBadge').style.display = verified ? 'none' : '';
        }

        const isNonEmpty   = v => v.length > 0;
        const isValidEmail = v => /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(v);
        const isValidPw    = v => v.length >= 8;

        function validateField(inputId, errId, checkFn) {
            const input = document.getElementById(inputId);
            const err   = document.getElementById(errId);
            const valid = checkFn(input.value.trim());
            input.classList.toggle('is-invalid', !valid);
            input.classList.toggle('is-valid',    valid);
            err.classList.toggle('show', !valid);
            return valid;
        }

        function clearFieldValidation(inputId, errId) {
            const input = document.getElementById(inputId);
            const err   = document.getElementById(errId);
            if (input) input.classList.remove('is-invalid', 'is-valid');
            if (err)   err.classList.remove('show');
        }

        function clearAllValidation() {
            [['inp_fullname','err_fullname'],['inp_nationality','err_nationality'],
             ['inp_email','err_email'],['inp_email_pw','err_email_pw'],['inp_newpw','err_newpw']]
                .forEach(([i, e]) => clearFieldValidation(i, e));
        }

        function validateProfileForm() {
            const a = validateField('inp_fullname',    'err_fullname',    isNonEmpty);
            const b = validateField('inp_nationality', 'err_nationality', isNonEmpty);
            const c = validateField('inp_email',       'err_email',       isValidEmail);
            return a && b && c;
        }

        function validatePasswordForm() {
            const a = validateField('inp_email_pw', 'err_email_pw', isValidEmail);
            const b = validateField('inp_newpw',    'err_newpw',    isValidPw);
            return a && b;
        }

        async function saveProfile(e) {
            e.preventDefault();
            if (!validateProfileForm()) return;

            const btn = document.getElementById('saveProfileBtn');
            const fb  = document.getElementById('profileFeedback');
            btn.disabled = true;
            hideFeedback(fb);

            const newEmail     = document.getElementById('inp_email').value.trim();
            const emailChanged = newEmail !== (_currentProfile.email || '');
            const isConfirmed  = emailChanged ? false : (_currentProfile.isEmailConfirmed || false);

            const payload = {
                fullName:         document.getElementById('inp_fullname').value.trim(),
                email:            newEmail,
                nationality:      document.getElementById('inp_nationality').value.trim(),
                isEmailConfirmed: isConfirmed
            };

            try {
                const res  = await fetch('/api/account/profile/update', {
                    method: 'PUT', credentials: 'include',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                const data = await res.json();

                if (data.isSuccess) {
                    _currentProfile = { ..._currentProfile, ...payload };
                    document.getElementById('saveProfileBtn').disabled = true;
                    document.getElementById('displayName').textContent  = payload.fullName;
                    document.getElementById('displayEmail').textContent = payload.email;
                    if (emailChanged) setEmailVerifiedUI(false);
                    showFeedback(fb, 'success', '<i class="bi bi-check-circle-fill"></i> Profile updated successfully.');
                    Vault.alert('success', 'Profile saved!', 3000);
                } else {
                    btn.disabled = false;
                    showFeedback(fb, 'error', '<i class="bi bi-x-circle-fill"></i> ' + (data.message || 'Update failed.'));
                }
            } catch {
                btn.disabled = false;
                showFeedback(fb, 'error', '<i class="bi bi-x-circle-fill"></i> Network error. Please try again.');
            }
        }

        async function startEmailVerification() {
            if (!validateField('inp_email', 'err_email', isValidEmail)) {
                Vault.alert('warning', 'Enter a valid email address first.', 3000);
                return;
            }
            _otpMode      = 'verify';
            _pendingEmail = document.getElementById('inp_email').value.trim();
            await sendOtp(_pendingEmail);
        }

        async function markEmailVerified() {
            const payload = {
                fullName:         document.getElementById('inp_fullname').value.trim()    || _currentProfile.fullName,
                email:            document.getElementById('inp_email').value.trim()        || _currentProfile.email,
                nationality:      document.getElementById('inp_nationality').value.trim()  || _currentProfile.nationality,
                isEmailConfirmed: true
            };

            try {
                const res  = await fetch('/api/account/profile/update', {
                    method: 'PUT', credentials: 'include',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                const data = await res.json();

                if (data.isSuccess) {
                    _currentProfile = { ..._currentProfile, ...payload };
                    setEmailVerifiedUI(true);
                    Vault.alert('success', 'Email verified successfully!', 4000);
                } else {
                    Vault.alert('error', data.message || 'Could not save verification status.', 4000);
                }
            } catch {
                Vault.alert('error', 'Network error while saving verification.', 4000);
            }
        }

        async function changePassword(e) {
            e.preventDefault();
            if (!validatePasswordForm()) return;

            _otpMode         = 'password';
            _pendingEmail    = document.getElementById('inp_email_pw').value.trim();
            _pendingPassword = document.getElementById('inp_newpw').value;
            await sendOtp(_pendingEmail);
        }

        async function doPasswordReset() {
            const fb  = document.getElementById('pwFeedback');
            const btn = document.getElementById('changePwBtn');
            btn.disabled = true;
            hideFeedback(fb);

            try {
                const res  = await fetch('/api/account/update-password', {
                    method: 'POST', credentials: 'include',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email: _pendingEmail, password: _pendingPassword })
                });
                const data = await res.json();

                if (data.isSuccess) {
                    setVal('inp_newpw', '');
                    checkStrength('');
                    clearFieldValidation('inp_newpw', 'err_newpw');
                    btn.disabled = true;
                    showFeedback(fb, 'success', '<i class="bi bi-check-circle-fill"></i> Password updated successfully.');
                    Vault.alert('success', 'Password changed!', 3000);
                } else {
                    btn.disabled = false;
                    showFeedback(fb, 'error', '<i class="bi bi-x-circle-fill"></i> ' + (data.message || 'Password update failed.'));
                }
            } catch {
                btn.disabled = false;
                showFeedback(fb, 'error', '<i class="bi bi-x-circle-fill"></i> Network error. Please try again.');
            } finally {
                _pendingPassword = null;
            }
        }

        async function sendOtp(email) {
            Vault.loader.show('Sending OTP…');
            try {
                const res  = await fetch(`/api/account/send-otp?email=${encodeURIComponent(email)}`,
                    { credentials: 'include' });
                const data = await res.json();
                Vault.loader.hide();
                if (data.isSuccess) {
                    _otpKey = data.result;
                    openOtpModal(`Enter the 6-digit code sent to <strong>${email}</strong>`);
                } else {
                    Vault.alert('error', data.message || 'Failed to send OTP.', 4000);
                }
            } catch {
                Vault.loader.hide();
                Vault.alert('error', 'Failed to send OTP. Please try again.', 4000);
            }
        }

        function openOtpModal(msg) {
            document.getElementById('otpModalMsg').innerHTML = msg;
            document.getElementById('otpModalBackdrop').style.display = 'flex';
            hideFeedback(document.getElementById('otpFeedback'));
            const boxes = document.querySelectorAll('.otp-box');
            boxes.forEach(b => { b.value = ''; b.classList.remove('is-invalid'); });
            boxes[0].focus();
        }

        function closeOtpModal() {
            document.getElementById('otpModalBackdrop').style.display = 'none';
            _otpKey  = null;
            _otpMode = null;
        }

        async function verifyOtp() {
            const boxes = document.querySelectorAll('.otp-box');
            const otp   = [...boxes].map(b => b.value).join('');
            const fb    = document.getElementById('otpFeedback');

            if (otp.length < 6 || [...boxes].some(b => !b.value)) {
                boxes.forEach(b => { if (!b.value) b.classList.add('is-invalid'); });
                showFeedback(fb, 'error', '<i class="bi bi-x-circle-fill"></i> Please fill all 6 digits.');
                return;
            }

            const btn = document.getElementById('verifyOtpBtn');
            btn.disabled = true;
            hideFeedback(fb);

            try {
                const res  = await fetch('/api/account/verify-otp', {
                    method: 'POST', credentials: 'include',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ otpKey: _otpKey, otp })
                });
                const data = await res.json();

                if (data.isSuccess) {
                    const mode = _otpMode;
                    closeOtpModal();
                    if (mode === 'verify')        await markEmailVerified();
                    else if (mode === 'password') await doPasswordReset();
                } else {
                    boxes.forEach(b => b.classList.add('is-invalid'));
                    showFeedback(fb, 'error',
                        '<i class="bi bi-x-circle-fill"></i> ' + (data.message || 'Invalid OTP. Please try again.'));
                }
            } catch {
                showFeedback(fb, 'error',
                    '<i class="bi bi-x-circle-fill"></i> Verification failed. Please try again.');
            } finally {
                btn.disabled = false;
            }
        }

        async function resendOtp() {
            if (!_pendingEmail) return;
            hideFeedback(document.getElementById('otpFeedback'));
            document.querySelectorAll('.otp-box').forEach(b => { b.value = ''; b.classList.remove('is-invalid'); });
            await sendOtp(_pendingEmail);
        }

        function initOtpInputs() {
            const boxes = document.querySelectorAll('.otp-box');
            boxes.forEach((box, i) => {
                box.addEventListener('input', () => {
                    box.classList.remove('is-invalid');
                    box.value = box.value.replace(/\D/g, '');
                    if (box.value && i < boxes.length - 1) boxes[i + 1].focus();
                });
                box.addEventListener('keydown', e => {
                    if (e.key === 'Backspace' && !box.value && i > 0) boxes[i - 1].focus();
                });
                box.addEventListener('paste', e => {
                    e.preventDefault();
                    const digits = (e.clipboardData.getData('text') || '').replace(/\D/g, '').slice(0, 6);
                    digits.split('').forEach((d, idx) => { if (boxes[idx]) boxes[idx].value = d; });
                    boxes[Math.min(digits.length, boxes.length - 1)].focus();
                });
            });
        }

        function confirmDeleteAccount() {
            Vault.confirm(
                { title: 'Delete Account?',
                  message: 'This will permanently delete your account and all data. This cannot be undone.',
                  confirmText: 'Delete Forever', cancelText: 'Cancel' },
                async () => {
                    Vault.loader.show('Deleting account…');
                    try {
                        const res  = await fetch('/api/account/profile/delete',
                            { method: 'DELETE', credentials: 'include' });
                        const data = await res.json();
                        Vault.loader.hide();
                        if (data.isSuccess) {
                            await fetch('/api/account/logout?logOutAllDevices=true',
                                { method: 'POST', credentials: 'include' });
                            window.location.href = '/Home/Auth';
                        } else {
                            Vault.alert('error', data.message || 'Delete failed.', 4000);
                        }
                    } catch {
                        Vault.loader.hide();
                        Vault.alert('error', 'Delete failed. Please try again.', 4000);
                    }
                }
            );
        }

        function checkStrength(val) {
            const bars   = [1,2,3,4].map(n => document.getElementById('bar' + n));
            const hint   = document.getElementById('pwHint');
            const clrs   = ['weak','fair','good','strong'];
            const labels = ['Too weak','Fair','Good','Strong'];
            bars.forEach(b => b.className = 'pw-bar');

            let score = 0;
            if (val.length >= 8) score++;
            if (/[A-Z]/.test(val) && /[a-z]/.test(val)) score++;
            if (/\d/.test(val)) score++;
            if (/[^A-Za-z0-9]/.test(val)) score++;

            for (let i = 0; i < score; i++) bars[i].classList.add(clrs[Math.max(score - 1, 0)]);
            hint.textContent = val ? (labels[score - 1] || 'Strong') : 'Enter a password';
            hint.style.color = score < 2 ? '#ef4444' : score < 4 ? '#d97706' : '#16a34a';
        }

        function togglePw(inputId, btn) {
            const input   = document.getElementById(inputId);
            const showing = input.type === 'text';
            input.type    = showing ? 'password' : 'text';
            btn.querySelector('i').className = 'bi bi-eye' + (showing ? '' : '-slash');
        }

        let _fbTimers = new WeakMap();

        function showFeedback(el, type, html) {
            el.innerHTML  = html;
            el.className  = 'inline-feedback ' + type;
            if (_fbTimers.has(el)) clearTimeout(_fbTimers.get(el));
            _fbTimers.set(el, setTimeout(() => hideFeedback(el), 6000));
        }

        function hideFeedback(el) {
            el.className = 'inline-feedback';
            el.innerHTML = '';
        }
    </script>
}